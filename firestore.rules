rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Allow if UID matches an entry in /admins/ OR if the user is signed in (more permissive for school setup)
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        // Fallback: if we are in a debug/setup phase, we can allow certain UIDs or check email
        request.auth.token.email == "yasserr2025@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Competition Rules ---
    match /competitions/{compId} {
      allow read: if true; 
      
      function isValidCompetition(data) {
        return data.status in ['idle', 'active', 'drawing', 'finished']
          && (data.get('title', '') is string && data.get('title', '').size() <= 500)
          && (data.get('question', '') is string && data.get('question', '').size() <= 5000)
          && (data.get('questionType', '') is string)
          && (data.get('prizeImageUrl', '') is string)
          && (data.get('adImageUrl', '') is string)
          && (data.get('winnerPhotoUrl', '') is string)
          && (data.get('adLink', '') is string)
          && (data.get('correctAnswer', '') is string);
      }

      allow create: if (isAdmin() || isSignedIn()) && isValidCompetition(incoming()); // Relax for setup
      allow update: if (isAdmin() || isSignedIn()) && isValidCompetition(incoming());
      allow delete: if isAdmin();

      // --- Answer Sub-collection ---
      match /answers/{answerId} {
        allow read: if true; 
        allow list: if true; 

        function isValidAnswer(data) {
          return (isSignedIn() ? data.studentId == request.auth.uid : (data.studentId is string && data.studentId.size() > 0))
            && data.studentName is string && data.studentName.size() <= 100
            && data.answerText is string && data.answerText.size() <= 1000
            && (data.get('isCorrect', false) is bool)
            && (data.get('reviewed', false) is bool);
        }

        allow create: if (isSignedIn() || (incoming().studentId is string))
          && isValidAnswer(incoming())
          && get(/databases/$(database)/documents/competitions/$(compId)).data.status == 'active';
        
        allow update: if isAdmin(); // Only admin can mark as correct or review
      }
    }

    // --- Student Rules ---
    match /students/{studentId} {
      allow read: if true; 
      allow list: if true; 
      
      function isValidStudent(data) {
        return data.nationalId is string && data.nationalId.size() <= 20
          && data.name is string && data.name.size() <= 100;
      }

      allow create: if (isSignedIn() && studentId == request.auth.uid && isValidStudent(incoming()))
         || (!isSignedIn() && studentId == incoming().uid && isValidStudent(incoming()));
      
      allow update: if (isSignedIn() && studentId == request.auth.uid && isValidStudent(incoming()))
         || (!isSignedIn() && studentId == incoming().uid && isValidStudent(incoming()));
    }

    // --- Admin Whitelist ---
    match /admins/{adminId} {
      allow read: if true; // Allowed so the app can verify admin status locally or via auth
      allow write: if false; // Only manageable via Firebase Console or special script
    }
  }
}
